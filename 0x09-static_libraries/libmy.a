islower.c/      0           0     0     644     250       `
#include "main.h"
/**
 * _islower - Checks if a character is lowercase.
 * @c: The character to be checked.
 *
 * Return: 1 if character is lowercase, 0 if not.
 */
int _islower(int c)
{
	if (c >= 'a' && c <= 'z')
		return (1);
	else
		return (0);
}
isupper.c/      0           0     0     644     256       `
#include "main.h"

/**
 * _isupper - checks for uppercase character
 * @c: ascii code for the character to check
 *
 * Return: Always 0.
 */
int _isupper(int c)
{
	int upc;

	if (c <= 90 && c >= 65)
	{
		upc = 1;
	}
	else
	{
		upc = 0;
	}
	return (upc);
}
