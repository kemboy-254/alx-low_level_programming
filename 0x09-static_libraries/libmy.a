#include "main.h"

/**
 * _abs - Prints out the absolute value.
 *
 * @n: Placeholder for the integer input.
 *
 * Return: The absolute value.
 */

int _abs(int n)

{
	if (n >= 0)
		return (n);
	else
		return (-n);
}

